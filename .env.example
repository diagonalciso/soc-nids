# soc-nids — network IDS dashboard (Suricata sidecar)
NIDS_HOST=0.0.0.0
NIDS_PORT=8102

# Suricata eve.json (JSON EVE log). install.sh configures Suricata to write here.
EVE_JSON=/var/log/suricata/eve.json

# Monitored interface + your protected network (display + suricata.yaml HOME_NET).
NIDS_IFACE=eth0
NIDS_HOME_NET=10.10.0.0/16

# In-memory rolling alert buffer size.
NIDS_RING=500
